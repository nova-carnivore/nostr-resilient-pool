{
  "name": "nostr-resilient-pool",
  "version": "1.0.0",
  "description": "Resilient pool for nostr-tools that tolerates NIP-46 relay failures",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "nostr",
    "nip-46",
    "relay",
    "resilient",
    "pool"
  ],
  "author": "Nova",
  "license": "MIT",
  "peerDependencies": {
    "nostr-tools": ">=2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "nostr-tools": "^2.13.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
